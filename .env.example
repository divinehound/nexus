# Database (shared PostgreSQL service)
# Use a dedicated DB for Claude Nexus (recommended: claude_nexus)
DATABASE_URL=postgresql://nexus_app:change_me@localhost:5432/claude_nexus

# Blockchain APIs
ALCHEMY_API_KEY=
HELIUS_API_KEY=

# Twitter/X API
TWITTER_BEARER_TOKEN=

# Marketplace APIs
OPENSEA_API_KEY=
RESERVOIR_API_KEY=

# Auth
JWT_SECRET=

# WalletConnect (get from https://cloud.reown.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# App
API_PORT=4000
WEB_PORT=3000
NODE_ENV=development
